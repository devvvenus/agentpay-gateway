{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@agentpay/shared": ["packages/shared/src/index.ts"],
      "@agentpay/db": ["packages/db/src/index.ts"],
      "@agentpay/payments": ["packages/payments/src/index.ts"],
      "@agentpay/adapters": ["packages/adapters/src/index.ts"],
      "@agentpay/agent": ["packages/agent/src/index.ts"],
      "three": ["node_modules/@types/three/index.d.ts"]
    }
  }
}
