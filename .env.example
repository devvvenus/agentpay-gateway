# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENTPAY_NETWORK=ARC-TESTNET
AGENTPAY_PAYMENT_MODE=x402
ALLOW_MAINNET=false

# Arc / Circle Nanopayments / x402
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_EXPLORER_URL=https://testnet.arcscan.app
USDC_DECIMALS=6
SELLER_ADDRESS=0x0000000000000000000000000000000000000000
SELLER_PRIVATE_KEY=
BUYER_ADDRESS=0x0000000000000000000000000000000000000000
BUYER_PRIVATE_KEY=
SELLER_ADDRESS_1=
SELLER_ADDRESS_2=
SELLER_ADDRESS_3=
CIRCLE_GATEWAY_API_KEY=
CIRCLE_GATEWAY_BASE_URL=
X402_FACILITATOR_URL=
CIRCLE_GATEWAY_BALANCE_HINT_USDC=
AGENTPAY_ADMIN_API_KEY=
# Required in production x402 mode. Give this only to the presenter or invited judge.
AGENTPAY_RUNNER_API_KEY=
# Hard ceiling for one authenticated agent run. Keep this at or below the funded testnet balance.
AGENTPAY_MAX_RUN_BUDGET_USDC=0.010000
AGENTPAY_WEBHOOK_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local upstreams
AGENTPAY_WORKER_URL=http://localhost:8000
# Required for every paid worker call. Do not expose this value to browsers.
AGENTPAY_WORKER_GATEWAY_SECRET=
# Local-only escape hatch; keep false in any deployed environment.
AGENTPAY_ALLOW_INSECURE_WORKER=false
AGENTPAY_ALLOW_LOCAL_UPSTREAMS=false
AGENTPAY_PAYER_URL=http://localhost:8000/payer/pay-resource
AGENTPAY_PAYER_API_KEY=replace-with-a-long-random-secret
CIRCLE_ACCEPT_TERMS=1
AGENTPAY_MCP_SERVER_URL=http://localhost:8000/mcp
AGENTPAY_DELEGATION_URL=http://localhost:8000/agent/delegate
AGENTPAY_INFERENCE_URL=http://localhost:8000/inference/complete
AGENTPAY_INFERENCE_MODEL=qwen3:14b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=90
AGENTPAY_RSS_PAYWALL_URL=http://localhost:8000/rss/paywall
AGENTPAY_PUBLISHER_API_URL=
AGENTPAY_ALLOWED_HOSTS=localhost,127.0.0.1,docs.arc.io,developers.circle.com,docs.x402.org,lepton.thecanteenapp.com,www.arc.network,agentpay-gateway.vercel.app,agentpay-gateway-beige.vercel.app

# Optional observability/eval
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
